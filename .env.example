# ── SENTINEL Environment Config ───────────────────────────
# Copy to .env and fill in before hackathon

# Datadog (get from DD account → API Keys)
DD_API_KEY=your_datadog_api_key
DD_APP_KEY=your_datadog_app_key

# Braintrust (get from braintrust.dev → Settings)
BRAINTRUST_API_KEY=your_braintrust_api_key
BRAINTRUST_PROJECT_ID=sentinel-medagent-demo

# ElevenLabs (get from elevenlabs.io → Profile)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel — professional voice

# Cleric (get from cleric.ai → API docs)
CLERIC_API_KEY=your_cleric_api_key
CLERIC_BASE_URL=https://api.cleric.ai

# Server
PORT=8080

# Demo mode — seeds 60 days of synthetic outcomes on startup
SEED_DEMO_DATA=true
